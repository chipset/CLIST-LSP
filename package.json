{
  "name": "clist-language-server",
  "displayName": "IBM CLIST Language Server",
  "description": "VS Code language server support for IBM CLIST files.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "clist",
    "ibm",
    "mainframe",
    "language server",
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:clist",
    "onCommand:clistLsp.restartServer"
  ],
  "main": "./client/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "clist",
        "aliases": [
          "CLIST",
          "IBM CLIST"
        ],
        "extensions": [
          ".clist",
          ".clst",
          ".exec"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "clist",
        "scopeName": "source.clist",
        "path": "./syntaxes/clist.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "clistLsp.restartServer",
        "title": "CLIST: Restart Language Server",
        "category": "CLIST"
      }
    ]
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "license": "MIT"
}
