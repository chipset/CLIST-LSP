{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "IBM CLIST",
  "scopeName": "source.clist",
  "patterns": [
    {
      "match": "^\\s*(/\\*|\\*).*$",
      "name": "comment.line.clist"
    },
    {
      "match": "\\b(PROC|SET|IF|THEN|ELSE|DO|END|GOTO|EXIT|READ|WRITE|CONTROL|ERROR|REPEAT)\\b",
      "name": "keyword.control.clist"
    },
    {
      "match": "&[A-Za-z0-9$#@_.-]+",
      "name": "variable.other.readwrite.clist"
    },
    {
      "match": "^\\s*([A-Za-z$#@][A-Za-z0-9$#@_.-]*)\\s*:",
      "captures": {
        "1": {
          "name": "entity.name.label.clist"
        }
      }
    },
    {
      "match": "\\b[0-9]+\\b",
      "name": "constant.numeric.clist"
    },
    {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.clist"
    },
    {
      "begin": "'",
      "end": "'",
      "name": "string.quoted.single.clist"
    }
  ]
}
